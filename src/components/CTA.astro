---
interface Props {
  title: string;
  body?: string;
}

const { title, body } = Astro.props;
---

<section class="my-16 px-8 py-10 rounded-2xl border border-neutral-300 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-900">
  <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
    
    <div class="space-y-2">
      <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100 leading-tight">
        {title}
      </h2>
      {body && (
        <p class="text-base text-neutral-700 dark:text-neutral-300 leading-relaxed">
          {body}
        </p>
      )}
    </div>

    <div class="flex flex-wrap gap-4 text-sm">
      <a
        href="/contact"
        class="px-5 py-2.5 rounded-full font-medium
               text-neutral-50 dark:text-neutral-950
               bg-neutral-900 dark:bg-neutral-100
               hover:bg-neutral-700 dark:hover:bg-neutral-200
               transition"
      >
        Contact
      </a>

      <a
        href="/work"
        class="px-5 py-2.5 rounded-full font-medium border
               border-neutral-500 dark:border-neutral-400
               text-neutral-900 dark:text-neutral-100
               hover:bg-neutral-200 dark:hover:bg-neutral-800
               transition"
      >
        View Work
      </a>
    </div>

  </div>
</section>
