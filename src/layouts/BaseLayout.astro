---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const defaultDescription = "AI workflows for small businesses that reduce overwhelm by improving how information flows through your business.";
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title ? `${title} — Borgart` : "Borgart — AI workflows for small businesses"}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <!-- ===== Fonts ===== -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- ===== SEO ===== -->
    <meta name="description" content={description || defaultDescription} />
    <meta name="keywords" content="AI workflows small business, business automation, document workflow, information management, Southwest Florida, AI consulting" />

    <!-- ===== Open Graph ===== -->
    <meta property="og:title" content={title ? `${title} — Borgart` : "Borgart — AI workflows for small businesses"} />
    <meta property="og:description" content={description || defaultDescription} />
    <meta property="og:url" content="https://www.borgart.ai" />
    <meta property="og:type" content="website" />

    <!-- ===== Twitter Card ===== -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title ? `${title} — Borgart` : "Borgart — AI workflows for small businesses"} />
    <meta name="twitter:description" content={description || defaultDescription} />

    <!-- ===== Structured Data ===== -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "George Rogers",
      "url": "https://www.borgart.ai",
      "description": "Helping small businesses reduce overwhelm by designing simple AI-assisted workflows around documents, email, and follow-ups.",
      "sameAs": [],
      "knowsAbout": [
        "AI workflows",
        "small business automation",
        "document management",
        "information workflows",
        "business process design"
      ]
    }
    </script>
  </head>

  <body class="min-h-screen font-sans" style="background: var(--bg); color: var(--text-primary);">
    <div class="min-h-screen flex flex-col">

      <!-- ===== Header / Nav ===== -->
      <header class="w-full max-w-[800px] mx-auto px-6 pt-8">
        <nav class="flex items-baseline justify-between">
          <a href="/" class="text-[0.95rem] font-semibold tracking-tight hover:opacity-70 transition" style="color: var(--text-primary);">
            Borgart
          </a>
          <div class="flex gap-7">
            <a href="/courses" class={`text-[0.82rem] transition hover:opacity-100 ${currentPath === '/courses' ? 'font-medium opacity-100' : 'opacity-50'}`} style="color: var(--text-primary);">
              Courses
            </a>
            <a href="/how-i-work" class={`text-[0.82rem] transition hover:opacity-100 ${currentPath === '/how-i-work' ? 'font-medium opacity-100' : 'opacity-50'}`} style="color: var(--text-primary);">
              How I Work
            </a>
            <a href="/about" class={`text-[0.82rem] transition hover:opacity-100 ${currentPath === '/about' ? 'font-medium opacity-100' : 'opacity-50'}`} style="color: var(--text-primary);">
              About
            </a>
            <a href="/companion-ai" class={`text-[0.82rem] transition hover:opacity-100 ${currentPath === '/companion-ai' ? 'font-medium opacity-100' : 'opacity-50'}`} style="color: var(--text-primary);">
              Companion AI
            </a>
            <a href="/contact" class={`text-[0.82rem] transition hover:opacity-100 ${currentPath === '/contact' ? 'font-medium opacity-100' : 'opacity-50'}`} style="color: var(--text-primary);">
              Contact
            </a>
          </div>
        </nav>
      </header>

      <!-- ===== Main Content ===== -->
      <main class="flex-1 w-full max-w-[640px] mx-auto px-6 pt-6 pb-2">
        <slot />
      </main>

      <!-- ===== Footer ===== -->
      <footer class="w-full max-w-[800px] mx-auto px-6 mt-16 pt-10 pb-8" style="border-top: 1px solid var(--border-light);">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div class="text-[0.75rem]" style="color: var(--text-tertiary);">
            Borgart · borgart.ai © {new Date().getFullYear()}
          </div>
          <div class="flex gap-5">
            <a href="/courses" class="text-[0.75rem] hover:opacity-100 transition" style="color: var(--text-tertiary);">Courses</a>
            <a href="/how-i-work" class="text-[0.75rem] hover:opacity-100 transition" style="color: var(--text-tertiary);">How I Work</a>
            <a href="/about" class="text-[0.75rem] hover:opacity-100 transition" style="color: var(--text-tertiary);">About</a>
            <a href="/companion-ai" class="text-[0.75rem] hover:opacity-100 transition" style="color: var(--text-tertiary);">Companion AI</a>
            <a href="/contact" class="text-[0.75rem] hover:opacity-100 transition" style="color: var(--text-tertiary);">Contact</a>
          </div>
        </div>
      </footer>

    </div>
  </body>
</html>
