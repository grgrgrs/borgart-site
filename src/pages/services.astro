---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceCard from "../components/servicecard.jsx";   // ← REQUIRED

// ───────────────────────────────────────────────
// SEE → Visibility & clean structure
// ───────────────────────────────────────────────
const see = {
  title: "See",
  description: "Make information visible and reliable. Pull scattered data together so you can actually look at it clearly.",
  tiers: {
    one:   { name: "Gather & Clean Data", text: "Bring scattered data from spreadsheets, systems, or exports into one place — finally know what you have." },
    two:   { name: "Unified View", text: "Import, merge, normalize — one source of truth instead of six conflicting versions." },
    three: { name: "Daily Pulse Dashboard", text: "Simple, trustworthy visibility — a clear view of how things are moving week over week." }
  }
};

// ───────────────────────────────────────────────
// UNDERSTAND → Meaning, patterns, comparisons
// ───────────────────────────────────────────────
const understand = {
  title: "Understand",
  description: "See not just what is happening — but why. Turn visibility into patterns, comparisons, and leverage.",
  tiers: {
    one:   { name: "Solve One Pain", text: "Fix a recurring confusion with data you can trust." },
    two:   { name: "Compare & Explain", text: "See patterns across products, time, customers — meaning instead of noise." },
    three: { name: "Predict What’s Next", text: "Trends + signals before they're obvious — act earlier and smarter." }
  }
};

// ───────────────────────────────────────────────
// ACT → Decisions, automation, AI execution
// ───────────────────────────────────────────────
const act = {
  title: "Act",
  description: "Use what we know to change outcomes. From decision support to workflow automation and AI execution.",
  tiers: {
    one:   { name: "Reduce Repetition", text: "Get hours back every week — automate tedious tasks." },
    two:   { name: "Decision Assist", text: "Summaries, reminders, insights when needed — faster decisions, less friction." },
    three: { name: "AI That Drives Outcomes", text: "Automation with oversight and guardrails — smart execution, your control." }
  }
};
---

<BaseLayout title="Services" description="See clearly. Understand better. Act effectively.">

  <!-- Header -->
  <section class="max-w-3xl mx-auto text-left pt-10 pb-8 space-y-3">
    <h1 class="text-3xl font-semibold tracking-tight">Services</h1>
    <p class="text-lg opacity-85 leading-relaxed">
      Here are ways we can work together — each with a low-friction way to begin,
      and each providing standalone value even if nothing more happens.
    </p>

    <ul class="text-[1rem] opacity-85 space-y-1 leading-snug mt-2">
      <li>“Our research data felt like it was held hostage by Pharaoh’s scribes.”</li>
      <li>“If someone could just tell me the top 20 vendors we paid last year, I'd be happy.”</li>
    </ul>


  </section>

  <!-- 3 PILLARS - RENDER HERE -->
  <section class="max-w-3xl mx-auto flex flex-col gap-10 pb-12">
    <ServiceCard {...see} />
    <ServiceCard {...understand} />
    <ServiceCard {...act} />
  </section>

  <!-- CTA -->
  <section class="text-center py-16 space-y-6">
    <p class="text-lg opacity-80 max-w-xl mx-auto">
      Most clients start small — two to five weeks — and finish with something
      useful, durable, and immediately valuable.
    </p>
    <a 
      href="/contact" 
      class="inline-block px-6 py-3 rounded-md bg-gray-900 text-white hover:opacity-80 transition font-medium"
    >
      Start with a Conversation
    </a>
  </section>

</BaseLayout>
