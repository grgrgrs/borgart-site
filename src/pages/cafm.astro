---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "CAFM";
const description = "AI vs Standard Report Matrix — George Rogers";
---

<BaseLayout title={pageTitle} description={description}>

  <section class="pt-16 pb-16">
    <p class="text-[0.88rem] mb-8" style="color: var(--text-secondary);">
      Created by George Rogers for CAFM discussion May 11, 2026.
    </p>
    <a href="/ai_vs_standard_report_matrix_grogers_051126.png" target="_blank" rel="noopener">
      <img
        src="/ai_vs_standard_report_matrix_grogers_051126.png"
        alt="AI vs Standard Report Matrix"
        style="width: calc(100% + 160px); margin-left: -80px; border-radius: 8px; border: 1px solid var(--border); display: block; cursor: zoom-in;"
      />
    </a>
    <p class="text-[0.78rem] mt-3" style="color: var(--text-tertiary);">
      <a href="/ai_vs_standard_report_matrix_grogers_051126.png" target="_blank" rel="noopener" style="color: var(--text-tertiary); text-decoration: underline;">View full size →</a>
    </p>
  </section>

</BaseLayout>
